# OpenClaw 环境变量配置示例
# 复制此文件为 .env 并填入你的配置

# 天气设置
CITY=北京

# 企业微信 Webhook
WECOM_WEBHOOK=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Discord
DISCORD_WEBHOOK_URL=

# OpenAI API (用于 AI 功能)
OPENAI_API_KEY=

# Slack
SLACK_WEBHOOK_URL=

# 存储阈值 (百分比)
THRESHOLD_CPU=80
THRESHOLD_MEM=85
THRESHOLD_DISK=90
